def _on_ymax(change):
    _state['y_max'] = float(change['new'])
    if not _state['auto_y']:
        _plot_trial(_state['idx'])

def _on_stim_end(change):
    factor = _unit_factor(_state['units'])
    _state['stim_end'] = float(change['new']) / factor
