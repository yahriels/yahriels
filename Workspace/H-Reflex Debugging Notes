def _dedup_legend(ax, **legend_kwargs):
    handles, labels = ax.get_legend_handles_labels()
    seen, h2, l2 = set(), [], []
    for h, l in zip(handles, labels):
        if l in seen:
            continue
        seen.add(l); h2.append(h); l2.append(l)
    ax.legend(h2, l2, **legend_kwargs)


